{
  "name": "kosl",
  "displayName": "KOSL Support",
  "description": "Syntax highlighting and formatting for Krait Object Serialization Language (KOSL)",
  "version": "0.2.1",
  "publisher": "KraitDev",
  "icon": "assets/kosl-icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "kosl",
        "aliases": ["KOSL", "kosl"],
        "extensions": [".kosl"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/kosl-icon.svg",
          "dark": "./assets/kosl-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "kosl",
        "scopeName": "source.kosl",
        "path": "./syntaxes/kosl.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "kosl-icons",
        "label": "KOSL Icons",
        "path": "./assets/icon-theme.json"
      }
    ]
  }
}
